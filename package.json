{
  "name": "kokoro-reader",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:gh-pages": "VITE_ENABLE_URL_INGEST=false npm run build",
    "preview": "vite preview",
    "test": "vitest run",
    "check:tts-manifest": "node scripts/check-tts-manifest.mjs",
    "check:browser-imports": "node scripts/check-browser-imports.mjs",
    "check:kokoro-chunk": "node scripts/check-kokoro-chunk.mjs",
    "check:deployed-assets": "node scripts/check-deployed-assets.mjs"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "dompurify": "^3.3.3",
    "jsdom": "^26.1.0",
    "kokoro-js": "^1.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remark": "^15.0.1",
    "remark-parse": "^11.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^4.1.2"
  }
}
