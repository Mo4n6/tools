{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "checkJs": true,
    "lib": ["ES2022"],
    "types": ["node"]
  },
  "include": ["vite.config.ts", "server/**/*.ts", "scripts/**/*.mjs"]
}
